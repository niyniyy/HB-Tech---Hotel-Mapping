# Copy this file to .env and fill in your values
# Never push .env to git

# Database
DATABASE_URL=postgresql+asyncpg://postgres:yourpassword@localhost:5432/hotel_mapping
SYNC_DATABASE_URL=postgresql+psycopg2://postgres:yourpassword@localhost:5432/hotel_mapping

# Redis / Celery
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# App
APP_NAME=HB Hotel Mapping Engine
APP_VERSION=1.0.0
DEBUG=True